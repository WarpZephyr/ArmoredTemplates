typedef struct(Encoding& encoding)
{
    dl_uint32 offset;
    dl_size size;
    TextureFormat format;
    TextureType type;
    dl_char mipmap;
    dl_char reserved;
    dl_uint16 width;
    dl_uint16 height;
    dl_uint32 pitch;
    dl_uint32 unk14;
    dl_uint32 nameOffset;
    dl_uint32 numData;
    
    local quad pos <hidden=true> = FTell();
    if (nameOffset > 0)
    {
        FSeek(nameOffset);
        if (encoding == EN_UTF16)
        {
            wstring name <bgcolor=cYellow>;
        }
        else
        {
            string name <bgcolor=cYellow>;
        }
    }
    
    if (offset > 0 && size > 0)
    {
        FSeek(offset);
        ubyte data[size] <bgcolor=cAqua>;
    }
    
    FSeek(pos);
} TpfTexAttributePs3 <bgcolor=cLtGreen, read=ReadTpfTexAttributePs3, optimize=false>;

string ReadTpfTexAttributePs3(TpfTexAttributePs3& tex)
{
    if (tex.nameOffset > 0)
    {
        if (tpf.header.encoding == EN_UTF16)
        {
            return StringToWString(tex.name);
        }
        else
        {
            return tex.name;
        }
    }
    else
    {
        return "";
    }
}

typedef struct
{
    TpfFileHeader header;
    switch (header.platform)
    {
        case PF_WIN32:
            TpfTexAttributeWin32 textures(header.encoding)[header.numTexture];
            break;
        case PF_XBOX360:
            TpfTexAttributeXbox360 textures(header.encoding)[header.numTexture];
            break;
        case PF_PLAYSTATION3:
            TpfTexAttributePs3 textures(header.encoding)[header.numTexture];
            break;
        default:
            Assert(false, Str("Unknown platform: %d", header.platform));
            break;
    }
} Tpf;

